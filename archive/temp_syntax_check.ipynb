    "import ast\n",
    "from pathlib import Path\n",
    "text = Path('app.py').read_text(encoding='utf-8')\n",
    "try:\n",
    "    ast.parse(text)\n",
    "    print('OK')\n",
    "except SyntaxError as e:\n",
    "    print(f'SyntaxError: {e.msg} at line {e.lineno} col {e.offset}')\n",
    "    print(e.text)"
   ]
  }
